# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log

# Build outputs
dist/
build/
.turbo/
.next/
out/

# Compiled Vite config artifacts
vite.config.js
vite.config.d.ts

# TypeScript build info
*.tsbuildinfo

# Environment files (never commit secrets)
.env
.env.local
.env.*.local
.env.deployment
.env.production
!.env.example

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# LevelDB state databases (binary, auto-created at runtime)
midnight-level-db/
packages/contracts/midnight-level-db/

# Compiled ZK keys (large binaries, auto-generated by compact compiler)
packages/contracts/managed/*/keys/
packages/contracts/managed/tmp_*/

# Private state storage (created during deployment)
packages/contracts/.private-state/

# Secrets - NEVER commit these
*.pem
*.key
*seed*phrase*
*mnemonic*
credentials.json
secrets.json

# Misc
*.tgz
*.tar.gz
.cache/

# Next.js migration artifacts (reverted)
apps/web/app/
apps/web/next-env.d.ts
apps/web/next.config.mjs

# Managed contract build outputs
packages/contracts/managed/*/compiler/
packages/contracts/managed/.build-skipped
packages/contracts/managed/.gitkeep
