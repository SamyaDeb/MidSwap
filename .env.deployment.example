# MidSwap Deployment Configuration
# Copy this file to .env.deployment and fill in your values
# NEVER commit .env.deployment to git!

# =============================================================================
# DEPLOYER CREDENTIALS
# =============================================================================

# Your 24-word BIP-39 seed phrase for the deployer wallet
# Generate one at: https://iancoleman.io/bip39/ (use offline!)
# Or use: npx @scure/bip39 generate
DEPLOYER_SEED_PHRASE="your 24 word seed phrase here"

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Network to deploy to: preprod or mainnet
NETWORK=preprod

# Override proof server URL (optional, defaults to http://localhost:6300)
# PROOF_SERVER_URL=http://localhost:6300

# =============================================================================
# CONTRACT PARAMETERS
# =============================================================================

# Trading fee in basis points (30 = 0.30%)
# FEE_BPS=30

# Token symbols for the trading pair
# TOKEN0_SYMBOL=tNight
# TOKEN1_SYMBOL=mUSDC

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. NEVER commit this file to version control
# 2. Use a dedicated deployment wallet (not your main wallet)
# 3. For mainnet, use a hardware wallet or secure key management
# 4. Keep minimal funds in the deployment wallet
# 5. Rotate keys after deployment if possible
#
# =============================================================================
# USAGE
# =============================================================================
#
# 1. Copy this file:
#    cp .env.deployment.example .env.deployment
#
# 2. Fill in your seed phrase
#
# 3. Run deployment:
#    source .env.deployment && pnpm --filter @midswap/contracts deploy:auto
#
# Or use the seed phrase directly (less secure, visible in shell history):
#    DEPLOYER_SEED_PHRASE="..." pnpm --filter @midswap/contracts deploy:auto
#
