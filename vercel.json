{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/indexer",
      "destination": "https://indexer.preprod.midnight.network/api/v4/graphql"
    },
    {
      "source": "/swap",
      "destination": "/"
    },
    {
      "source": "/pools",
      "destination": "/"
    },
    {
      "source": "/mev",
      "destination": "/"
    }
  ]
}
