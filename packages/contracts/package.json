{
  "name": "@midswap/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.cjs",
    "build:compile": "compact compile src/LiquidityPool.compact managed/LiquidityPool",
    "build:check": "node scripts/check-compiler.js",
    "test": "vitest run",
    "deploy": "tsx scripts/deploy.ts",
    "deploy:preprod": "NETWORK=preprod tsx scripts/deploy.ts",
    "deploy:auto": "tsx scripts/deploy-automated.ts",
    "deploy:preprod-auto": "NETWORK=preprod tsx scripts/deploy-automated.ts",
    "init-pool": "tsx scripts/init-pool.ts",
    "deploy:musdc": "tsx scripts/deploy-musdc.ts",
    "init:musdc": "tsx scripts/init-musdc.ts",
    "redeploy:musdc": "tsx scripts/redeploy-musdc.ts",
    "test-transactions": "tsx scripts/test-transactions.ts",
    "test-transactions:readonly": "SKIP_TX_TESTS=1 tsx scripts/test-transactions.ts",
    "test:e2e": "tsx scripts/test-pool-flow.ts",
    "test:smoke": "tsx scripts/test-smoke.ts",
    "clean": "rm -rf managed/ dist/"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "^2.5.0",
    "@midnight-ntwrk/compact-runtime": "^0.15.0",
    "@midnight-ntwrk/dapp-connector-api": "^4.0.1",
    "@midnight-ntwrk/ledger": "^4.0.0",
    "@midnight-ntwrk/ledger-v8": "^8.0.3",
    "@midnight-ntwrk/midnight-js": "^4.0.4",
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-network-id": "^4.0.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-utils": "^4.0.4",
    "@midnight-ntwrk/wallet": "^5.0.0",
    "@midnight-ntwrk/wallet-api": "^5.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "^3.0.1"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-js-command": "^2.5.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-capabilities": "3.2.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-indexer-client": "1.2.0",
    "@midnight-ntwrk/wallet-sdk-shielded": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "playwright": "^1.59.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0",
    "ws": "8.20.0"
  }
