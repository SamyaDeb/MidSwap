# MidSwap Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# MIDNIGHT NETWORK CONFIGURATION
# ===========================================

# Midnight Preprod Network RPC Endpoint
VITE_MIDNIGHT_RPC_URL=wss://rpc.preprod.midnight.network

# Midnight Preprod Indexer GraphQL Endpoint
VITE_MIDNIGHT_INDEXER_URL=https://indexer.preprod.midnight.network/api/v4/graphql

# Local Proof Server URL (run via Docker)
# Start with: docker run -p 6300:6300 midnightntwrk/proof-server:8.0.3
VITE_PROOF_SERVER_URL=http://localhost:6300

# Network identifier
VITE_NETWORK=preprod

# ===========================================
# POOL ADDRESSES
# ===========================================

# tNight/mUSDC Pool Address (deployed contract address)
VITE_POOL_TNIGHT_MUSDC=

# MidnightUSDC contract address
VITE_MUSDC_ADDRESS=

# ZK assets are copied into the web build at /zk/OptimalAMM
VITE_ZK_BASE_URL=/zk/OptimalAMM

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

# Enable debug logging (true/false)
VITE_DEBUG=false

# Browser SDK log level
VITE_MIDSWAP_LOG_LEVEL=info
