# MidSwap Web App - Environment Variables
# Copy this file to .env.local and fill in your values

# Midnight Preprod Network
VITE_MIDNIGHT_RPC_URL=wss://rpc.preprod.midnight.network
VITE_MIDNIGHT_INDEXER_URL=/api/indexer
VITE_PROOF_SERVER_URL=/api/proof
VITE_NETWORK=preprod

# Deployed OptimalAMM Pool address (tNight/mUSDC on Preprod)
VITE_POOL_TNIGHT_MUSDC=57c54a7c61f60a1f769313d89a4191782fa92c7d91bb51e79bfc9256eca1229b

# Deployed MidnightUSDC token contract address
VITE_MUSDC_ADDRESS=c85172925beae8334c01135cfbd364cf2f6858e173be8c13bb82197890f645f4

# ZK assets base URL (served from /public/zk/)
VITE_ZK_BASE_URL=/zk/OptimalAMM

# Debug
VITE_DEBUG=false
VITE_MIDSWAP_LOG_LEVEL=info
